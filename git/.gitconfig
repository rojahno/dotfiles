[user]
        name = rojahno
        email = andreas.rojahn.sunde@jbf.no
        signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEjwTWmY/Yy5WoM1+5othn29Kd2U6q9ZNH4yiwmHFxSl
[gpg]
        format = ssh
[gpg "ssh"]
        program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
        allowedSignersFile = ~/.ssh/allowed_signers
[commit]
        gpgsign = false
[core]
        excludesfile = ~/.gitignore_global
[alias]
        logs = log --format='%h %G? %GS %s'
